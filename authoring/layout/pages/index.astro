---
import {
  getArticles,
  getArticleUrl,
  isDraftArticle
} from "../lib/content/articles"
import { formatArticleDate } from "../lib/dates"
import { siteTitle } from "../lib/site"
import SiteDocument from "../components/SiteDocument.astro"

const articles = await getArticles()
const articleCount = articles.length
---

<SiteDocument title={siteTitle}>
  <main data-article-count={articleCount}>
    <h1>{siteTitle}</h1>
    <ol>
      {
        articles.map((article) => (
          <li>
            <article data-article-status={article.data.status}>
              <h2>
                <a href={getArticleUrl(article)}>{article.data.title}</a>
              </h2>
              {isDraftArticle(article) && <p>Draft</p>}
              {article.data.subtitle && <p>{article.data.subtitle}</p>}
              <p>
                <time datetime={article.data.created.toISOString()}>
                  {formatArticleDate(article.data.created)}
                </time>
              </p>
            </article>
          </li>
        ))
      }
    </ol>
  </main>
</SiteDocument>
