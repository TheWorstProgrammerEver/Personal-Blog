---
import {
  getListedArticles
} from "../lib/content/articles"
import {
  siteDescription,
  siteTitle
} from "../lib/site"
import PostList from "../components/PostList.astro"
import SiteDocument from "../components/SiteDocument.astro"

const articles = await getListedArticles()
const articleCount = articles.length
---

<SiteDocument title={siteTitle} description={siteDescription} canonicalPath="/">
  <main class="home" data-article-count={articleCount}>
    <header class="home__header">
      <h1>{siteTitle}</h1>
      <nav class="site-nav" aria-label="Site">
        <a href="/tags/">Tags</a>
        <a href="/search/">Search</a>
      </nav>
    </header>
    <PostList articles={articles} />
  </main>
</SiteDocument>
