---
import { render } from "astro:content"
import ArticleDocument from "../../components/ArticleDocument.astro"
import ArticleLinks from "../../components/ArticleLinks.astro"
import ArticleStatusMarker from "../../components/ArticleStatusMarker.astro"
import {
  getRoutableArticles,
  getArticleSlug,
  getTagUrl
} from "../../lib/content/articles"
import { formatArticleDate } from "../../lib/dates"
import { siteTitle } from "../../lib/site"

export const getStaticPaths = async () =>
  (await getRoutableArticles())
    .map((article) => ({
      params: { slug: getArticleSlug(article) },
      props: { article }
    }))

const { article } = Astro.props
const { Content } = await render(article)
---

<ArticleDocument article={article}>
  <main class="post-shell">
    <article class="post">
      <header class="post__header">
        <p class="site-backlink"><a href="/">{siteTitle}</a></p>
        <h1>{article.data.title}</h1>
        <ArticleStatusMarker article={article} />
        {article.data.subtitle && <p class="post__subtitle">{article.data.subtitle}</p>}
        <p class="post__meta">
          <time datetime={article.data.created.toISOString()}>
            {formatArticleDate(article.data.created)}
          </time>
        </p>
        {
          article.data.tags.length > 0 && (
            <ul class="post__tags" aria-label="Tags" role="list">
              {article.data.tags.map((tag) => <li><a href={getTagUrl(tag)}>{tag}</a></li>)}
            </ul>
          )
        }
      </header>
      <div class="prose">
        <Content />
        <ArticleLinks links={article.data.links} />
      </div>
    </article>
  </main>
</ArticleDocument>
